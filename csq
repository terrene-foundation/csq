#!/usr/bin/env bash
# csq — Claude Squad account manager
# Usage:
#   csq login <N>         Save current session's account as slot N
#   csq run <N>           Start Claude Code on account N (isolated keychain)
#   csq status            Show all accounts + quota
#   csq suggest           Suggest which account to /login to
#   csq cleanup           Remove stale PID cache files
#   csq help              Show this help

set -euo pipefail

ACCOUNTS_DIR="$HOME/.claude/accounts"
ENGINE="$ACCOUNTS_DIR/rotation-engine.py"

die() { echo "error: $*" >&2; exit 1; }

# Resolve Python 3 command for this platform. Windows has python/py instead
# of python3. Try in order, cache the result.
_find_python() {
  for cmd in python3 python py; do
    if command -v "$cmd" >/dev/null 2>&1; then
      if "$cmd" --version 2>&1 | grep -q "Python 3"; then
        echo "$cmd"
        return
      fi
    fi
  done
  die "Python 3 not found in PATH"
}
PY="$(_find_python)"

# Detect platform once
_detect_platform() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)
      if grep -qi microsoft /proc/version 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi ;;
    MINGW*|MSYS*|CYGWIN*) echo "git-bash" ;;
    *) echo "unknown" ;;
  esac
}
PLATFORM="$(_detect_platform)"

cmd_login() {
  local n="$1"
  [[ "$n" =~ ^[1-9][0-9]*$ ]] || die "account must be a positive integer, got: $n"

  local config_dir="$ACCOUNTS_DIR/config-$n"
  mkdir -p "$config_dir" "$ACCOUNTS_DIR/credentials"

  # Launch CC login with the account's config dir — opens browser.
  # NOTE: Do NOT wrap with `timeout` — it kills the TTY, preventing
  # claude auth login from detecting an interactive session and opening
  # the browser. The user can ctrl-C if needed.
  echo "Opening browser to log in for account $n..."
  env CLAUDE_CONFIG_DIR="$config_dir" claude auth login || die "Login failed"

  # After login, get email from the new session
  local email
  email=$(CLAUDE_CONFIG_DIR="$config_dir" claude auth status --json 2>/dev/null \
    | "$PY" -c "import json,sys; print(json.load(sys.stdin).get('email','unknown'))" 2>/dev/null \
    || echo "unknown")

  # Capture credentials. On macOS, CC stores them in the per-config-dir
  # keychain entry. On Linux/WSL/Windows, CC writes them directly to
  # $config_dir/.credentials.json. Try keychain first, then file.
  CSQ_CONFIG_DIR="$config_dir" CSQ_ACCT="$n" CSQ_CREDS_DIR="$ACCOUNTS_DIR/credentials" CSQ_PLATFORM="$PLATFORM" "$PY" -c "
import hashlib, json, os, subprocess, sys, unicodedata

config_dir = os.environ['CSQ_CONFIG_DIR']
n = os.environ['CSQ_ACCT']
creds_dir = os.environ['CSQ_CREDS_DIR']
platform = os.environ['CSQ_PLATFORM']

creds = None

# Path 1: macOS keychain
if platform == 'macos':
    normalized = unicodedata.normalize('NFC', config_dir)
    h = hashlib.sha256(normalized.encode()).hexdigest()[:8]
    service = f'Claude Code-credentials-{h}'
    import getpass
    try:
        r = subprocess.run(
            ['security', 'find-generic-password', '-a', getpass.getuser(), '-s', service, '-w'],
            capture_output=True, text=True, timeout=5,
        )
        if r.returncode == 0 and r.stdout.strip():
            raw = r.stdout.strip()
            try:
                creds = json.loads(raw)
            except json.JSONDecodeError:
                creds = json.loads(bytes.fromhex(raw).decode('utf-8'))
    except Exception:
        pass

# Path 2: file fallback (always tried — works on all platforms; on macOS,
# this is the secondary path if the keychain read failed)
if creds is None:
    dot_creds = os.path.join(config_dir, '.credentials.json')
    if os.path.exists(dot_creds):
        try:
            with open(dot_creds) as f:
                creds = json.load(f)
        except (OSError, json.JSONDecodeError):
            pass

if creds is None:
    print('  warning: could not read credentials after login', file=sys.stderr)
    sys.exit(0)

# Save canonical copy
cred_file = os.path.join(creds_dir, f'{n}.json')
with open(cred_file, 'w') as f:
    json.dump(creds, f, indent=2)
if platform != 'git-bash':
    os.chmod(cred_file, 0o600)

# Mirror into config dir (CC reads it at startup)
dot_creds = os.path.join(config_dir, '.credentials.json')
with open(dot_creds, 'w') as f:
    json.dump(creds, f, indent=2)
if platform != 'git-bash':
    os.chmod(dot_creds, 0o600)

print(f'  Credentials saved to slot {n}')
" 2>&1

  echo "$n" > "$config_dir/.current-account"

  # Clear any stale broker-failure flag from a prior cycle. csq login is
  # the explicit "user fixed it" signal: a fresh canonical/N.json with a
  # valid OAuth session means the dead-RT condition the flag warns about
  # no longer applies. Without this, the ⚠LOGIN-NEEDED prefix in the
  # statusline would persist for hours until the broker happened to fire
  # and clear it on its own.
  rm -f "$ACCOUNTS_DIR/credentials/$n.broker-failed"

  # Save profile
  CSQ_ACCT="$n" CSQ_EMAIL="$email" CSQ_FILE="$ACCOUNTS_DIR/profiles.json" "$PY" -c "
import json, os
f = os.environ['CSQ_FILE']
try:
    with open(f) as fh: d = json.load(fh)
except (FileNotFoundError, json.JSONDecodeError, ValueError):
    d = {'accounts': {}}
d.setdefault('accounts', {})[os.environ['CSQ_ACCT']] = {'email': os.environ['CSQ_EMAIL'], 'method': 'oauth'}
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" 2>/dev/null

  printf 'Account %s saved (%s).\n' "$n" "$email"
}

cmd_run() {
  # Parse args: optional <N>, optional -p <profile>, rest pass through to claude.
  # If <N> is omitted, auto-resolve based on number of configured accounts.
  local n=""
  local profile=""
  local claude_args=()

  # First positional may or may not be the account number
  if [[ $# -gt 0 ]] && [[ "$1" =~ ^[1-9][0-9]*$ ]]; then
    n="$1"
    shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile|-p)
        shift
        [[ $# -ge 1 ]] || die "--profile requires an argument (e.g., --profile mm)"
        profile="$1"
        shift
        ;;
      *)
        claude_args+=("$1")
        shift
        ;;
    esac
  done

  # Auto-resolve account number if not specified
  if [[ -z "$n" ]]; then
    local creds_dir="$ACCOUNTS_DIR/credentials"
    local accounts=()
    if [[ -d "$creds_dir" ]]; then
      for f in "$creds_dir"/*.json; do
        [[ -f "$f" ]] || continue
        local base
        base="$(basename "$f" .json)"
        [[ "$base" =~ ^[1-9][0-9]*$ ]] && accounts+=("$base")
      done
    fi

    case "${#accounts[@]}" in
      0)
        # No csq accounts configured — be invisible, just run vanilla claude
        # (with the same profile overlay if -p was given, applied to ~/.claude directly)
        if [[ -n "$profile" ]]; then
          die "no csq accounts configured. -p only works with csq accounts."
        fi
        exec claude ${claude_args[@]+"${claude_args[@]}"}
        ;;
      1)
        n="${accounts[0]}"
        ;;
      *)
        die "multiple accounts configured (${accounts[*]}). Specify which: csq run <N>"
        ;;
    esac
  fi

  local config_dir="$ACCOUNTS_DIR/config-$n"
  local cred_file="$ACCOUNTS_DIR/credentials/$n.json"
  local default_dir="$HOME/.claude"
  mkdir -p "$config_dir"

  [[ -f "$cred_file" ]] || die "no credentials for account $n — run: csq login $n"

  # --- Symlink shared artifacts from ~/.claude ---
  # Only credentials, account identity, and settings.json stay isolated.
  # settings.json is built fresh on every run from the canonical default
  # (~/.claude/settings.json) plus any --profile overlay. Each csq terminal
  # gets its own snapshot — global default changes don't affect running terminals.
  # Everything else (history, projects/memory, sessions, commands, skills, etc.)
  # is symlinked so csq terminals see the same state as default terminals.
  local isolated=(".credentials.json" ".current-account" ".csq-account" ".live-pid" ".claude.json" "accounts" "settings.json" ".quota-cursor")
  shopt -s nullglob
  for item in "$default_dir"/* "$default_dir"/.*; do
    local base
    base="$(basename "$item")"

    # Skip . and .. and .DS_Store
    [[ "$base" == "." || "$base" == ".." || "$base" == ".DS_Store" ]] && continue

    # Skip isolated files
    local skip=false
    for iso in "${isolated[@]}"; do
      [[ "$base" == "$iso" ]] && { skip=true; break; }
    done
    $skip && continue

    local target="$config_dir/$base"

    # Already a correct link — skip. On Git Bash/Windows, junctions don't
    # report via readlink, so we just check existence and re-create if older.
    if [[ "$PLATFORM" != "git-bash" ]]; then
      if [[ -L "$target" ]] && [[ "$(readlink "$target")" == "$item" ]]; then
        continue
      fi
      if [[ -e "$target" ]] && [[ ! -L "$target" ]]; then
        rm -rf "$target"
      fi
      [[ -L "$target" ]] && rm -f "$target"
      ln -s "$item" "$target"
    else
      # Windows/Git Bash: directory junctions for dirs, copy for files.
      # Junctions don't need admin like symlinks do.
      [[ -e "$target" ]] && rm -rf "$target" 2>/dev/null
      if [[ -d "$item" ]]; then
        # mklink /J needs Windows-style paths
        cmd //c "mklink /J \"$(cygpath -w "$target" 2>/dev/null || echo "$target")\" \"$(cygpath -w "$item" 2>/dev/null || echo "$item")\"" >/dev/null 2>&1 \
          || cp -r "$item" "$target"
      else
        cp "$item" "$target" 2>/dev/null || true
      fi
    fi
  done

  # --- Account-specific setup (per-config-dir, no global state) ---
  # NOTE: We used to back-sync $config_dir/.credentials.json → credentials/N.json
  # here, but that was unsafe: if a previous `csq swap M` left M's tokens in
  # this config dir, the back-sync would copy M's tokens into credentials/N.json
  # (cross-account poisoning). The engine's backsync() runs on every statusline
  # render and uses refresh-token CONTENT MATCHING to identify the correct slot
  # — that's race-proof and account-safe. We rely on it instead.

  # .csq-account marker — durable identity record. Snapshot reads this on
  # CC restart to populate .current-account. csq swap rewrites it. Per-dir,
  # no contention with other csq terminals.
  #
  # Written BEFORE the canonical copy so the synchronous broker call below
  # has a marker to look up. Order: marker → broker → cred copy.
  echo "$n" > "$config_dir/.csq-account"

  # Synchronous broker refresh before copying canonical. This closes the
  # "new terminal inherits a dead canonical" failure mode: if canonical's
  # refresh token has been rotated out from under us by a past race, the
  # broker's recovery path will try each live sibling's RT and heal
  # canonical before we copy it. If both primary and recovery fail, the
  # broker subcommand exits 2 and we abort here with a clear message
  # instead of letting CC boot with a dead credential file and
  # die 30 seconds later with a confusing 401.
  #
  # Common case cost: ~50 ms (broker reads canonical, sees the token is
  # not within the refresh window, early-returns). Only pays the Anthropic
  # round-trip (~1-2 s) when canonical actually needs a refresh.
  if ! CLAUDE_CONFIG_DIR="$config_dir" "$PY" "$ENGINE" broker; then
    die "account $n's refresh token is dead — run: csq login $n"
  fi

  # CC v2.1+ reads .credentials.json at startup. Copy from canonical so
  # swap_to() changes take effect on restart. Atomic write (temp + mv) so
  # CC never sees a half-written credentials file if csq is killed mid-copy.
  # Must run AFTER the broker call above so we pick up the freshly-refreshed
  # canonical instead of a stale one.
  cp "$cred_file" "$config_dir/.credentials.json.tmp"
  mv "$config_dir/.credentials.json.tmp" "$config_dir/.credentials.json"
  if [[ "$PLATFORM" != "git-bash" ]]; then
    chmod 600 "$config_dir/.credentials.json"
  fi

  # Initial .current-account so legacy code paths see *something* before the
  # snapshot fires on first statusline. The snapshot will overwrite this on
  # CC startup with the value from .csq-account.
  echo "$n" > "$config_dir/.current-account"

  # Stale .live-pid from a prior CC process in this config dir would block
  # the snapshot's cheap path. Remove it so the new CC's first statusline
  # call re-snapshots fresh.
  rm -f "$config_dir/.live-pid"

  # NOTE: We do NOT call init-keychain here. The macOS keychain is a global
  # resource and contends under load (15+ concurrent csq terminals). CC
  # reads .credentials.json at startup and only falls back to the keychain
  # if the file is missing — which it isn't, because we just wrote it.

  # Mark onboarding complete so CC doesn't show the setup wizard
  CSQ_CONFIG="$config_dir/.claude.json" "$PY" -c "
import json, os
p = os.environ['CSQ_CONFIG']
try:
    with open(p) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
if not d.get('hasCompletedOnboarding'):
    d['hasCompletedOnboarding'] = True
    with open(p, 'w') as f: json.dump(d, f, indent=2)
" 2>/dev/null || true

  # --- Build settings.json: default + optional profile overlay ---
  # Canonical default = ~/.claude/settings.json (always the base, never mutated by csq)
  # Profile overlay   = ~/.claude/settings-<name>.json (deep-merged on top if -p given)
  # Result is written as a real file in config-N, isolated from other terminals.
  CSQ_DEFAULT="$default_dir/settings.json" \
  CSQ_OVERLAY="${profile:+$default_dir/settings-${profile}.json}" \
  CSQ_OUTPUT="$config_dir/settings.json" \
  "$PY" -c "
import json, os, sys
default_path = os.environ['CSQ_DEFAULT']
overlay_path = os.environ.get('CSQ_OVERLAY') or ''
output_path = os.environ['CSQ_OUTPUT']

if not os.path.exists(default_path):
    print(f'default settings not found: {default_path}', file=sys.stderr)
    sys.exit(1)
with open(default_path) as f:
    merged = json.load(f)

if overlay_path:
    if not os.path.exists(overlay_path):
        print(f'profile not found: {overlay_path}', file=sys.stderr)
        sys.exit(1)
    with open(overlay_path) as f:
        overlay = json.load(f)
    def deep_merge(a, b):
        result = dict(a)
        for k, v in b.items():
            if k in result and isinstance(result[k], dict) and isinstance(v, dict):
                result[k] = deep_merge(result[k], v)
            else:
                result[k] = v
        return result
    merged = deep_merge(merged, overlay)

with open(output_path, 'w') as f:
    json.dump(merged, f, indent=2)
" || die "failed to build settings.json"

  local email
  email=$("$PY" "$ENGINE" email "$n" 2>/dev/null)
  local profile_label=""
  [[ -n "$profile" ]] && profile_label=" [profile: $profile]"
  echo "Starting Claude Code on account $n${email:+ ($email)}${profile_label}"
  exec env CLAUDE_CONFIG_DIR="$config_dir" claude ${claude_args[@]+"${claude_args[@]}"}
}

cmd_suggest() {
  local result
  result=$("$PY" "$ENGINE" suggest 2>/dev/null) || die "engine failed"

  local exhausted
  exhausted=$(echo "$result" | "$PY" -c "import json,sys; print(json.load(sys.stdin).get('exhausted', False))" 2>/dev/null)

  if [ "$exhausted" = "True" ]; then
    echo "All accounts exhausted."
    "$PY" "$ENGINE" status
  else
    local acct email pct
    acct=$(echo "$result" | "$PY" -c "import json,sys; print(json.load(sys.stdin)['account'])" 2>/dev/null)
    email=$(echo "$result" | "$PY" -c "import json,sys; print(json.load(sys.stdin)['email'])" 2>/dev/null)
    pct=$(echo "$result" | "$PY" -c "import json,sys; print(json.load(sys.stdin)['five_hour_used'])" 2>/dev/null)
    echo "Switch to account $acct ($email) — 5h: ${pct}% used"
    echo ""
    echo "  In Claude Code, run:  /login $email"
  fi
}

cmd_setkey() {
  local provider="${1:-}"
  local key="${2:-}"
  [[ -n "$provider" ]] || die "usage: csq setkey <provider> [key]
  providers:
    claude  Claude direct API (ANTHROPIC_API_KEY)
    mm      MiniMax M2.7 (ANTHROPIC_AUTH_TOKEN for https://api.minimax.io/anthropic)
    zai     Z.AI GLM-4.6 (ANTHROPIC_AUTH_TOKEN for https://api.z.ai/api/anthropic)
    ollama  Local Ollama (no key needed, uses http://localhost:11434)

  If [key] is omitted, csq reads it from stdin (keeps it out of shell history).
  Local providers (ollama) need no key — just run: csq setkey ollama
  Use:  ! csq setkey mm < <(pbpaste)   # paste from clipboard without echo"

  # Read key from stdin if not passed as argument
  if [[ -z "$key" ]]; then
    if [[ -t 0 ]]; then
      # Interactive stdin — prompt (skip for keyless providers)
      read -rsp "Paste key for $provider (Enter to skip for local providers): " key
      echo
    else
      # Piped stdin — read directly (empty is OK for keyless providers)
      read -r key || true
    fi
  fi

  # Hand off to Python to write the profile overlay, preserving existing fields
  CSQ_PROVIDER="$provider" CSQ_KEY="$key" "$PY" -c "
import json, os, sys
from pathlib import Path

provider = os.environ['CSQ_PROVIDER']
key = os.environ['CSQ_KEY']

# Primer file paths — installed alongside the rotation engine.
# Non-Anthropic models get both prepend (primacy) and append (recency)
# to bookend the system prompt with COC-critical instructions.
PRIMER_PATH = Path.home() / '.claude/accounts/3p-model-primer.md'
PRIMER_PREPEND_PATH = Path.home() / '.claude/accounts/3p-model-primer-prepend.md'

# Provider defaults. These define the skeleton written when the overlay
# file doesn't exist yet. If it DOES exist, we preserve all fields and
# only update the key field(s).
PROVIDERS = {
    'claude': {
        'key_fields': ['ANTHROPIC_API_KEY'],
        'skeleton': {
            'env': {
                'ANTHROPIC_API_KEY': '',
            }
        },
    },
    'mm': {
        'key_fields': ['ANTHROPIC_AUTH_TOKEN'],
        'skeleton': {
            'systemPromptFile': str(PRIMER_PREPEND_PATH),
            'appendSystemPromptFile': str(PRIMER_PATH),
            'env': {
                'ANTHROPIC_BASE_URL': 'https://api.minimax.io/anthropic',
                'ANTHROPIC_AUTH_TOKEN': '',
                'ANTHROPIC_MODEL': 'MiniMax-M2.7-highspeed',
                'ANTHROPIC_SMALL_FAST_MODEL': 'MiniMax-M2.7-highspeed',
                'ANTHROPIC_DEFAULT_SONNET_MODEL': 'MiniMax-M2.7-highspeed',
                'ANTHROPIC_DEFAULT_OPUS_MODEL': 'MiniMax-M2.7-highspeed',
                'ANTHROPIC_DEFAULT_HAIKU_MODEL': 'MiniMax-M2.7-highspeed',
                'API_TIMEOUT_MS': '3000000',
                'CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC': '1',
            }
        },
    },
    'zai': {
        'key_fields': ['ANTHROPIC_AUTH_TOKEN'],
        'skeleton': {
            'systemPromptFile': str(PRIMER_PREPEND_PATH),
            'appendSystemPromptFile': str(PRIMER_PATH),
            'env': {
                'ANTHROPIC_BASE_URL': 'https://api.z.ai/api/anthropic',
                'ANTHROPIC_AUTH_TOKEN': '',
                'ANTHROPIC_MODEL': 'glm-4.7',
                'ANTHROPIC_SMALL_FAST_MODEL': 'glm-4.5-air',
                'ANTHROPIC_DEFAULT_SONNET_MODEL': 'glm-4.7',
                'ANTHROPIC_DEFAULT_OPUS_MODEL': 'glm-4.7',
                'ANTHROPIC_DEFAULT_HAIKU_MODEL': 'glm-4.5-air',
                'API_TIMEOUT_MS': '3000000',
                'CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC': '1',
            }
        },
    },
    'ollama': {
        'key_fields': [],
        'skeleton': {
            'systemPromptFile': str(PRIMER_PREPEND_PATH),
            'appendSystemPromptFile': str(PRIMER_PATH),
            'env': {
                'ANTHROPIC_BASE_URL': 'http://localhost:11434',
                'ANTHROPIC_AUTH_TOKEN': 'ollama',
                'ANTHROPIC_API_KEY': '',
                'ANTHROPIC_MODEL': 'qwen3:latest',
                'ANTHROPIC_SMALL_FAST_MODEL': 'qwen3:latest',
                'ANTHROPIC_DEFAULT_SONNET_MODEL': 'qwen3:latest',
                'ANTHROPIC_DEFAULT_OPUS_MODEL': 'qwen3:latest',
                'ANTHROPIC_DEFAULT_HAIKU_MODEL': 'qwen3:latest',
                'API_TIMEOUT_MS': '3000000',
                'CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC': '1',
            }
        },
    },
}

if provider not in PROVIDERS:
    print(f'unknown provider: {provider} (must be one of {list(PROVIDERS.keys())})', file=sys.stderr)
    sys.exit(1)

config = PROVIDERS[provider]
profile_path = Path.home() / f'.claude/settings-{provider}.json'

# Load existing profile if it exists and is non-empty
existing = None
if profile_path.exists() and profile_path.stat().st_size > 0:
    try:
        existing = json.loads(profile_path.read_text())
    except json.JSONDecodeError:
        print(f'warning: {profile_path} is corrupted, replacing with defaults', file=sys.stderr)
        existing = None

if existing is None:
    # Seed with skeleton
    data = json.loads(json.dumps(config['skeleton']))  # deep copy
else:
    data = existing
    # Ensure env section exists
    data.setdefault('env', {})

# Always sync primer references if the provider skeleton has them.
# This ensures existing profiles pick up primers on re-run of setkey.
for primer_key in ('systemPromptFile', 'appendSystemPromptFile'):
    if primer_key in config['skeleton']:
        primer = config['skeleton'][primer_key]
        if Path(primer).exists():
            data[primer_key] = primer

# Update the key fields. Other fields (model, base URL, etc.) are preserved
# if already set by the user. If the profile didn't exist, the skeleton
# defaults provide them.
if config['key_fields'] and not key:
    print(f'error: provider {provider} requires a key', file=sys.stderr)
    sys.exit(1)
for key_field in config['key_fields']:
    data['env'][key_field] = key

# Atomic write
tmp = profile_path.with_suffix('.json.tmp')
tmp.write_text(json.dumps(data, indent=2))
if os.name != 'nt':
    os.chmod(tmp, 0o600)
os.replace(str(tmp), str(profile_path))

print(f'  Key set for profile \"{provider}\" → {profile_path}')
print(f'  Start CC with: csq run N -p {provider}')
" 2>&1
}

cmd_listkeys() {
  # Show configured provider profiles with masked keys
  "$PY" -c "
import json, os
from pathlib import Path

home = Path.home() / '.claude'
profiles = sorted(home.glob('settings-*.json'))
if not profiles:
    print('No provider profiles configured.')
    print('Configure one with: csq setkey <provider> [key]')
    exit()

print(f'{\"Profile\":<12} {\"Key set?\":<10} {\"Fingerprint\":<20} File')
print('-' * 75)
for p in profiles:
    name = p.stem.replace('settings-', '')
    if p.stat().st_size == 0:
        print(f'{name:<12} {\"empty\":<10} {\"\":<20} {p}')
        continue
    try:
        d = json.loads(p.read_text())
    except json.JSONDecodeError:
        print(f'{name:<12} {\"corrupt\":<10} {\"\":<20} {p}')
        continue
    env = d.get('env', {})
    key_val = env.get('ANTHROPIC_AUTH_TOKEN') or env.get('ANTHROPIC_API_KEY') or ''
    if key_val:
        fp = key_val[:8] + '…' + key_val[-6:] if len(key_val) > 20 else '<short>'
        print(f'{name:<12} {\"yes\":<10} {fp:<20} {p}')
    else:
        print(f'{name:<12} {\"no\":<10} {\"\":<20} {p}')
"
}

cmd_rmkey() {
  local provider="${1:-}"
  [[ -n "$provider" ]] || die "usage: csq rmkey <provider>"
  local profile_path="$HOME/.claude/settings-${provider}.json"
  if [[ ! -f "$profile_path" ]]; then
    die "no profile for $provider at $profile_path"
  fi
  rm -f "$profile_path"
  echo "Removed profile: $profile_path"
}

main() {
  # No args → default to `csq run` (which auto-resolves accounts).
  # First arg looks like a number or a flag → also treat as `csq run`.
  if [[ $# -eq 0 ]]; then
    cmd_run
    return
  fi
  if [[ "$1" =~ ^[1-9][0-9]*$ ]] || [[ "$1" == -* ]]; then
    cmd_run "$@"
    return
  fi

  local cmd="${1:-help}"

  case "$cmd" in
    login)
      shift
      [[ $# -ge 1 ]] || die "usage: csq login <N>"
      cmd_login "$1"
      ;;
    run|start)
      shift
      cmd_run "$@"
      ;;
    status|ls|quota)
      "$PY" "$ENGINE" status
      ;;
    suggest)
      cmd_suggest
      ;;
    swap)
      shift
      [[ $# -ge 1 ]] || die "usage: csq swap <N>  (swap THIS terminal to account N)"
      [[ "$1" =~ ^[1-9][0-9]*$ ]] || die "account must be a positive integer, got: $1"
      [[ -n "${CLAUDE_CONFIG_DIR:-}" ]] || die "csq swap only works in a csq terminal (CLAUDE_CONFIG_DIR not set — use 'csq run $1' instead)"
      "$PY" "$ENGINE" swap "$1"
      ;;
    cleanup)
      "$PY" "$ENGINE" cleanup
      ;;
    setkey)
      shift
      cmd_setkey "$@"
      ;;
    listkeys|keys)
      cmd_listkeys
      ;;
    rmkey)
      shift
      cmd_rmkey "$@"
      ;;
    help|-h|--help)
      cat <<'HELP'
csq — Claude Squad account manager

  csq                            Start Claude Code (auto-resolves account)
                                   0 accounts → vanilla claude
                                   1 account  → that account
                                   2+         → must specify N below
  csq run [N] [-p <prof>] [args] Same, with explicit account / profile / claude args
  csq login <N>                  Save current account as slot N (+ set up keychain)
  csq swap <N>                   Swap THIS terminal to account N (in-place, no restart)
  csq status                     Show all accounts + quota
  csq suggest                    Suggest which account to /login to
  csq cleanup                    Remove stale PID cache files

Provider profiles (API key management):
  csq setkey <prov> [key]        Set/update API key for a provider profile
                                 Providers: claude (direct API), mm, zai
                                 If [key] omitted, reads from stdin (safer)
  csq listkeys                   Show configured provider profiles (masked)
  csq rmkey <prov>               Remove a provider profile

  Then start CC with: csq run N -p <prov>

  csq help                       This message

When CC hits a rate limit, type inside CC:
  ! csq swap <N>                 Swap to account N. Works even when CC's LLM is
                                 rate-limited (the ! prefix runs as a local
                                 shell command, no LLM call). Your next message
                                 will use the new account, in the same conversation.

Settings model:
  ~/.claude/settings.json is the canonical default. csq NEVER mutates it.
  Profiles are overlays at ~/.claude/settings-<name>.json — only need to
  contain the diff (e.g., env vars to switch API provider).

  csq run 5             → uses default settings as-is
  csq run 5 -p mm       → deep-merges settings-mm.json over default
  csq run 5 -p mm --resume → same, plus claude --resume

  Each csq terminal gets its own settings.json snapshot at startup.
  No global state. No "switching back". Restart to change profile.

Setup:
  1. csq login 1    (opens browser, saves account 1's creds)
  2. Repeat for each account
  3. csq run 1      (start CC on account 1)
HELP
      ;;
    *)
      die "unknown command: $cmd. Try: csq help"
      ;;
  esac
}

main "$@"
