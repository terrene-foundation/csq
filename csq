cmd_rmkey() {
  local provider="${1:-}"
  [[ -n "$provider" ]] || die "usage: csq rmkey <provider>"
  local profile_path="$HOME/.claude/settings-${provider}.json"
  if [[ ! -f "$profile_path" ]]; then
    die "no profile for $provider at $profile_path"
  fi
  rm -f "$profile_path"
  echo "Removed profile: $profile_path"
}

cmd_models() {
  local provider="${1:-}"
  local new_model="${2:-}"
  local catalog_path="$HOME/.claude/accounts/model-catalog.json"

  CSQ_PROVIDER="$provider" CSQ_MODEL="$new_model" CSQ_CATALOG="$catalog_path" "$PY" -c "
import json, os, sys, subprocess
from pathlib import Path

provider = os.environ.get('CSQ_PROVIDER', '')
new_model = os.environ.get('CSQ_MODEL', '')
catalog_path = Path(os.environ['CSQ_CATALOG'])
home = Path.home() / '.claude'

MODEL_KEYS = [
    'ANTHROPIC_MODEL', 'ANTHROPIC_SMALL_FAST_MODEL',
    'ANTHROPIC_DEFAULT_SONNET_MODEL', 'ANTHROPIC_DEFAULT_OPUS_MODEL',
    'ANTHROPIC_DEFAULT_HAIKU_MODEL',
]

# Load catalog (from installed copy, or repo copy as fallback)
catalog = {}
if catalog_path.exists():
    try: catalog = json.loads(catalog_path.read_text())
    except (json.JSONDecodeError, OSError): pass

def get_current_model(prov):
    p = home / f'settings-{prov}.json'
    if not p.exists() or p.stat().st_size == 0:
        return None
    try:
        d = json.loads(p.read_text())
        return d.get('env', {}).get('ANTHROPIC_MODEL')
    except (json.JSONDecodeError, OSError):
        return None

def get_ollama_models():
    try:
        r = subprocess.run(['ollama', 'list'], capture_output=True, text=True, timeout=10)
        if r.returncode == 0:
            lines = r.stdout.strip().split('\n')[1:]  # skip header
            return [line.split()[0] for line in lines if line.strip()]
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return None

# --- Mode 1: list all profiles ---
if not provider:
    profiles = sorted(home.glob('settings-*.json'))
    if not profiles:
        print('No provider profiles configured.')
        print('Configure one with: csq setkey <provider> [key]')
        sys.exit()
    print(f\"{'Profile':<12} {'Model':<30} Status\")
    print('-' * 60)
    for p in profiles:
        name = p.stem.replace('settings-', '')
        if name == 'default':
            continue
        model = get_current_model(name)
        if not model:
            print(f'{name:<12} {\"(not configured)\":<30}')
            continue
        cat = catalog.get(name, {})
        latest = cat.get('latest')
        if latest and model == latest:
            status = '(latest)'
        elif latest and model != latest:
            status = f'(update: {latest})'
        else:
            status = ''
        print(f'{name:<12} {model:<30} {status}')
    sys.exit()

# --- Mode 2: show available models for provider ---
if not new_model:
    current = get_current_model(provider)
    cat = catalog.get(provider, {})

    if provider == 'ollama':
        models = get_ollama_models()
        if models is None:
            print('Ollama not found in PATH. Install from https://ollama.com')
            sys.exit(1)
        if not models:
            print('No models installed. Run: ollama pull qwen3:latest')
            sys.exit()
        print(f'Installed ollama models:')
        for m in models:
            marker = ' (active)' if m == current else ''
            print(f'  {m}{marker}')
    else:
        models = cat.get('models', [])
        latest = cat.get('latest')
        if not models:
            print(f'No model catalog for {provider}.')
            if not catalog:
                print('Run: csq update   (downloads the model catalog)')
            sys.exit(1)
        print(f'Available models for {provider}:')
        for m in models:
            tags = []
            if m == latest: tags.append('latest')
            if m == current: tags.append('active')
            tag_str = f'  ({', '.join(tags)})' if tags else ''
            print(f'  {m}{tag_str}')

    print(f'\nSwitch with: csq models {provider} <model>')
    sys.exit()

# --- Mode 3: switch model ---
profile_path = home / f'settings-{provider}.json'
if not profile_path.exists() or profile_path.stat().st_size == 0:
    print(f'No profile for {provider}. Run: csq setkey {provider}', file=sys.stderr)
    sys.exit(1)

cat = catalog.get(provider, {})
known_models = cat.get('models', [])
if provider == 'ollama':
    known_models = get_ollama_models() or []
if known_models and new_model not in known_models:
    print(f'Unknown model: {new_model}', file=sys.stderr)
    print(f'Available: {', '.join(known_models)}', file=sys.stderr)
    sys.exit(1)

try:
    data = json.loads(profile_path.read_text())
except json.JSONDecodeError:
    print(f'{profile_path} is corrupted', file=sys.stderr)
    sys.exit(1)

env = data.setdefault('env', {})
old_model = env.get('ANTHROPIC_MODEL', '(not set)')

for k in MODEL_KEYS:
    env[k] = new_model

tmp = profile_path.with_suffix('.json.tmp')
tmp.write_text(json.dumps(data, indent=2))
if os.name != 'nt':
    os.chmod(tmp, 0o600)
os.replace(str(tmp), str(profile_path))

print(f'  Model switched: {old_model} -> {new_model}')
print(f'  Restart your csq terminal to use the new model.')
" 2>&1
}

main() {
  # No args → default to `csq run` (which auto-resolves accounts).
  # First arg looks like a number or a flag → also treat as `csq run`.
  if [[ $# -eq 0 ]]; then
    cmd_run
    return
  fi
  if [[ "$1" =~ ^[1-9][0-9]*$ ]] || [[ "$1" == -* ]]; then
    cmd_run "$@"
    return
  fi

  local cmd="${1:-help}"

  case "$cmd" in
    login)
      shift
      [[ $# -ge 1 ]] || die "usage: csq login <N>"
      cmd_login "$1"
      ;;
    run|start)
      shift
      cmd_run "$@"
      ;;
    status|ls|quota)
      "$PY" "$ENGINE" status
      ;;
    suggest)
      cmd_suggest
      ;;
    swap)
      shift
      [[ $# -ge 1 ]] || die "usage: csq swap <N>  (swap THIS terminal to account N)"
      [[ "$1" =~ ^[1-9][0-9]*$ ]] || die "account must be a positive integer, got: $1"
      [[ -n "${CLAUDE_CONFIG_DIR:-}" ]] || die "csq swap only works in a csq terminal (CLAUDE_CONFIG_DIR not set — use 'csq run $1' instead)"
      "$PY" "$ENGINE" swap "$1"
      ;;
    cleanup)
      "$PY" "$ENGINE" cleanup
      ;;
    setkey)
      shift
      cmd_setkey "$@"
      ;;
    listkeys|keys)
      cmd_listkeys
      ;;
    rmkey)
      shift
      cmd_rmkey "$@"
      ;;
    models|model)
      shift
      cmd_models "$@"
      ;;
    update|upgrade)
      cmd_update
      ;;
    help|-h|--help)
      cat <<'HELP'
csq — Claude Squad account manager

  csq                            Start Claude Code (auto-resolves account)
                                   0 accounts → vanilla claude
                                   1 account  → that account
                                   2+         → must specify N below
  csq run [N] [-p <prof>] [args] Same, with explicit account / profile / claude args
  csq login <N>                  Save current account as slot N (+ set up keychain)
  csq swap <N>                   Swap THIS terminal to account N (in-place, no restart)
  csq status                     Show all accounts + quota
  csq suggest                    Suggest which account to /login to
  csq cleanup                    Remove stale PID cache files

Provider profiles (API key management):
  csq setkey <prov> [key]        Set/update API key for a provider profile
                                 Providers: claude (direct API), mm, zai
                                 If [key] omitted, reads from stdin (safer)
  csq listkeys                   Show configured provider profiles (masked)
  csq rmkey <prov>               Remove a provider profile

  Then start CC with: csq run N -p <prov>

Model management:
  csq models                     Show all profiles + current models
  csq models <prov>              List available models for a provider
  csq models <prov> <model>      Switch to a different model

  csq update                     Update csq + model catalog from GitHub
  csq help                       This message

When CC hits a rate limit, type inside CC:
  ! csq swap <N>                 Swap to account N. Works even when CC's LLM is
                                 rate-limited (the ! prefix runs as a local
                                 shell command, no LLM call). Your next message
                                 will use the new account, in the same conversation.

Settings model:
  ~/.claude/settings.json is the canonical default. csq NEVER mutates it.
  Profiles are overlays at ~/.claude/settings-<name>.json — only need to
  contain the diff (e.g., env vars to switch API provider).

  csq run 5             → uses default settings as-is
  csq run 5 -p mm       → deep-merges settings-mm.json over default
  csq run 5 -p mm --resume → same, plus claude --resume

  Each csq terminal gets its own settings.json snapshot at startup.
  No global state. No "switching back". Restart to change profile.

Setup:
  1. csq login 1    (opens browser, saves account 1's creds)
  2. Repeat for each account
  3. csq run 1      (start CC on account 1)
HELP
      ;;
    *)
      die "unknown command: $cmd. Try: csq help"
      ;;
  esac
}

main "$@"
