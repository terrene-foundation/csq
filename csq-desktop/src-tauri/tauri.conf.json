{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Code Session Quota",
  "version": "2.0.0",
  "identifier": "foundation.terrene.claude-squad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Code Session Quota",
        "width": 420,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://platform.claude.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "msi", "nsis"],
    "publisher": "Terrene Foundation",
    "homepage": "https://github.com/terrene-foundation/csq",
    "shortDescription": "Multi-provider session manager for Claude Code",
    "longDescription": "Code Session Quota (csq) — run Claude Code against local models, third-party APIs, or pool multiple Claude Max subscriptions with per-terminal isolation and quota monitoring.",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "appPosition": { "x": 160, "y": 200 },
        "applicationFolderPosition": { "x": 400, "y": 200 },
        "windowSize": { "width": 560, "height": 400 }
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"],
        "section": "devel"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "libappindicator-gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
