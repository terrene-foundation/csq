#!/usr/bin/env bash
# ccc — Claude Code multi-account launcher
# Usage:
#   ccc                  Launch with default (logged-in) account
#   ccc mm               Launch with MiniMax provider
#   ccc 1-7              Launch with specific Claude account
#   ccc next             Rotate to next Claude account (round-robin)
#   ccc status           Show all configured accounts
#   ccc login <N>        Login to account N (interactive)
#   ccc add <N> [email]  Add account N with optional email hint
#   ccc current          Show which account is active for rotation
#   ccc <any args>       Pass through to claude

set -euo pipefail

ACCOUNTS_DIR="$HOME/.claude/accounts"
CURRENT_FILE="$ACCOUNTS_DIR/.current"
PROFILES_FILE="$ACCOUNTS_DIR/profiles.json"

# Ensure accounts directory exists
mkdir -p "$ACCOUNTS_DIR"

# ─── Helpers ───────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }

# Get the current round-robin index (1-based)
get_current() {
  if [[ -f "$CURRENT_FILE" ]]; then
    cat "$CURRENT_FILE"
  else
    echo "1"
  fi
}

# Get total number of configured Claude accounts
get_max_account() {
  local max=0
  for f in "$ACCOUNTS_DIR"/{1,2,3,4,5,6,7}.json; do
    [[ -f "$f" ]] && max=$(basename "$f" .json)
  done
  echo "$max"
}

# Get account metadata from profiles.json
get_profile_field() {
  local account="$1" field="$2"
  if [[ -f "$PROFILES_FILE" ]]; then
    python3 -c "
import json, sys
try:
    d = json.load(open('$PROFILES_FILE'))
    print(d.get('accounts', {}).get('$account', {}).get('$field', ''))
except: pass
" 2>/dev/null
  fi
}

# Launch claude with a specific settings overlay
launch_with_settings() {
  local settings_file="$1"
  shift
  if [[ ! -f "$settings_file" ]]; then
    die "settings file not found: $settings_file"
  fi
  exec claude --settings "$settings_file" "$@"
}

# Launch claude with isolated config dir (for OAuth accounts)
launch_with_config_dir() {
  local config_dir="$1"
  shift
  if [[ ! -d "$config_dir" ]]; then
    die "account not configured. Run: ccc login $(basename "$config_dir")"
  fi
  export CLAUDE_CONFIG_DIR="$config_dir"
  exec claude "$@"
}

# Determine auth method for an account and launch accordingly
launch_account() {
  local n="$1"
  shift

  # Primary: per-account config dir (CLAUDE_CONFIG_DIR isolation)
  # Auth is in keychain (modern) or .credentials.json (legacy) — check .claude.json as init marker
  local rotation_config_dir="$ACCOUNTS_DIR/config-${n}"
  if [[ -d "$rotation_config_dir" ]] && { [[ -f "$rotation_config_dir/.claude.json" ]] || [[ -f "$rotation_config_dir/.credentials.json" ]]; }; then
    export CLAUDE_CONFIG_DIR="$rotation_config_dir"
    # Ensure onboarding state is patched (prevents first-run flow)
    _patch_onboarding_state "$rotation_config_dir"
    # Write .credentials.json into config dir (per-directory, no keychain conflicts)
    local cred_file="$ACCOUNTS_DIR/credentials/${n}.json"
    if [[ -f "$cred_file" ]]; then
      cp "$cred_file" "$rotation_config_dir/.credentials.json"
      chmod 600 "$rotation_config_dir/.credentials.json"
    fi
    # Poll all accounts in background so pick_best has fresh data from the start
    python3 "$HOME/.claude/accounts/rotation-engine.py" _poll_others \
      $(for i in 1 2 3 4 5 6 7; do echo "$i"; done) &>/dev/null &
    exec claude "$@"
  fi

  # Fallback: settings overlay
  local settings_file="$ACCOUNTS_DIR/${n}.json"
  if [[ -f "$settings_file" ]]; then
    launch_with_settings "$settings_file" "$@"
  fi

  # Fallback: old-style config dir
  local config_dir="$ACCOUNTS_DIR/${n}"
  if [[ -d "$config_dir" ]]; then
    launch_with_config_dir "$config_dir" "$@"
  fi

  die "account $n not configured. Run: ccc login $n && ccc setup"
}

# ─── Commands ──────────────────────────────────────────────

cmd_status() {
  echo "Claude Code Accounts"
  echo "━━━━━━━━━━━━━━━━━━━━"

  local current
  current=$(get_current)

  # MiniMax
  if [[ -f "$ACCOUNTS_DIR/mm.json" ]] || [[ -f "$HOME/.claude/settings-mm.json" ]]; then
    local mm_model
    mm_model=$(python3 -c "
import json
for f in ['$ACCOUNTS_DIR/mm.json', '$HOME/.claude/settings-mm.json']:
    try:
        d = json.load(open(f))
        print(d.get('env', {}).get('ANTHROPIC_MODEL', 'unknown'))
        break
    except: pass
" 2>/dev/null)
    echo "  mm  MiniMax ($mm_model)"
  fi

  # Claude accounts 1-7
  for n in 1 2 3 4 5 6 7; do
    local settings_file="$ACCOUNTS_DIR/${n}.json"
    local config_dir="$ACCOUNTS_DIR/${n}"
    local cred_file="$ACCOUNTS_DIR/credentials/${n}.json"
    local marker=" "
    [[ "$current" == "$n" ]] && marker="→"

    if [[ -f "$settings_file" ]]; then
      local email
      email=$(get_profile_field "$n" "email")
      local method
      method=$(get_profile_field "$n" "method")
      echo " $marker$n  ${email:-account $n} (${method:-token})"
    elif [[ -d "$config_dir" ]]; then
      local email
      email=$(get_profile_field "$n" "email")
      echo " $marker$n  ${email:-account $n} (oauth)"
    elif [[ -f "$cred_file" ]]; then
      local email
      email=$(get_profile_field "$n" "email")
      local method
      method=$(get_profile_field "$n" "method")
      echo " $marker$n  ${email:-account $n} (${method:-oauth})"
    else
      echo "  $n  (not configured)"
    fi
  done

  echo ""
  echo "current rotation: $(get_current)"
}

cmd_login() {
  local n="$1"
  [[ "$n" =~ ^[1-7]$ ]] || die "account must be 1-7, got: $n"

  # Ensure config dir exists with shared symlinks
  local config_dir="$ACCOUNTS_DIR/config-${n}"
  mkdir -p "$config_dir"

  # Symlink shared state to global ~/.claude/
  # sessions/ is shared so /rename + /resume work across config dirs
  for item in settings.json projects plugins sessions; do
    local target="$HOME/.claude/$item"
    local link="$config_dir/$item"
    if [[ -e "$target" ]] && [[ ! -L "$link" ]]; then
      # If real dir exists, remove it (setup_config_dirs merges first)
      [[ -d "$link" ]] && rm -rf "$link"
      [[ -e "$link" ]] && rm -f "$link"
      ln -sf "$target" "$link"
    fi
  done

  echo "Logging in to account $n..."
  echo "A browser will open. Sign in with the account you want for slot $n."
  echo ""

  # Remove stale credentials so claude auth login forces a fresh browser login
  rm -f "$config_dir/.credentials.json"

  # Logout first to clear any cached auth state
  CLAUDE_CONFIG_DIR="$config_dir" claude auth logout 2>/dev/null || true

  # Login INSIDE the config dir — this initializes interactive session state
  CLAUDE_CONFIG_DIR="$config_dir" claude auth login || die "login failed"

  # Get the email
  local email
  email=$(CLAUDE_CONFIG_DIR="$config_dir" claude auth status --json 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin).get('email','unknown'))" 2>/dev/null || echo "unknown")

  # Update profile
  _update_profile "$n" "$email" "oauth"

  # Extract credentials to credentials/N.json and config dir .credentials.json
  # Modern Claude Code writes to macOS keychain (shared, single entry).
  # We MUST extract immediately after login before the next login overwrites it.
  mkdir -p "$ACCOUNTS_DIR/credentials"
  local keychain_cred
  # Claude Code stores credentials per config dir: Claude Code-credentials-{sha256(dir)[:8]}
  local keychain_suffix
  keychain_suffix=$(echo -n "$config_dir" | shasum -a 256 | cut -c1-8)
  local keychain_service="Claude Code-credentials-${keychain_suffix}"
  keychain_cred=$(security find-generic-password -s "$keychain_service" -w 2>/dev/null || true)
  # Fallback to generic service name (older Claude Code versions, hex-encoded)
  if [[ -z "$keychain_cred" ]]; then
    local keychain_hex
    keychain_hex=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)
    if [[ -n "$keychain_hex" ]]; then
      keychain_cred=$(echo "$keychain_hex" | xxd -r -p)
    fi
  fi
  if [[ -n "$keychain_cred" ]]; then
    echo "$keychain_cred" > "$ACCOUNTS_DIR/credentials/${n}.json"
    chmod 600 "$ACCOUNTS_DIR/credentials/${n}.json"
    # Also write to config dir so Claude Code can use it without keychain
    echo "$keychain_cred" > "$config_dir/.credentials.json"
    chmod 600 "$config_dir/.credentials.json"
  elif [[ -f "$config_dir/.credentials.json" ]]; then
    # Fallback: credential file written by older Claude Code
    cp "$config_dir/.credentials.json" "$ACCOUNTS_DIR/credentials/${n}.json"
    chmod 600 "$ACCOUNTS_DIR/credentials/${n}.json"
  else
    echo "error: no credentials found after login for account $n" >&2
  fi

  # Patch config dir with onboarding state from ~/.claude.json
  # (prevents first-run flow when launching with CLAUDE_CONFIG_DIR)
  _patch_onboarding_state "$config_dir"

  # Reset quota for this account
  python3 -c "
import json, time
f = '$ACCOUNTS_DIR/quota.json'
try:
    state = json.load(open(f))
except:
    state = {'accounts': {}}
state.setdefault('accounts', {})['$n'] = {
    'five_hour': {'used_percentage': 0, 'resets_at': 0},
    'seven_day': {'used_percentage': 0, 'resets_at': 0},
    'updated_at': time.time(),
}
with open(f, 'w') as fh:
    json.dump(state, fh, indent=2)
" 2>/dev/null

  echo ""
  echo "Account $n ($email) configured. Launch with: ccc $n"
}

cmd_add() {
  local n="$1"
  local email="${2:-}"
  [[ "$n" =~ ^[1-7]$|^mm$ ]] || die "account must be 1-7 or mm, got: $n"

  if [[ "$n" == "mm" ]]; then
    # MiniMax — just symlink existing settings-mm.json
    if [[ -f "$HOME/.claude/settings-mm.json" ]]; then
      ln -sf "$HOME/.claude/settings-mm.json" "$ACCOUNTS_DIR/mm.json"
      echo "MiniMax linked from settings-mm.json"
    else
      die "~/.claude/settings-mm.json not found"
    fi
    return
  fi

  local settings_file="$ACCOUNTS_DIR/${n}.json"

  echo "How do you want to authenticate account $n?"
  echo "  1) OAuth login (browser) — for Claude.ai subscriptions"
  echo "  2) Auth token            — paste a long-lived token"
  echo "  3) API key               — paste a Console API key"
  echo ""
  read -rp "Choice [1/2/3]: " choice

  case "$choice" in
    1)
      cmd_login "$n"
      return
      ;;
    2)
      read -rsp "Auth token for account $n: " token
      echo ""
      cat > "$settings_file" <<JSONEOF
{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "$token"
  }
}
JSONEOF
      chmod 600 "$settings_file"
      _update_profile "$n" "${email:-account $n}" "token"
      echo "Account $n configured with auth token."
      ;;
    3)
      read -rsp "API key for account $n: " key
      echo ""
      cat > "$settings_file" <<JSONEOF
{
  "env": {
    "ANTHROPIC_API_KEY": "$key"
  }
}
JSONEOF
      chmod 600 "$settings_file"
      _update_profile "$n" "${email:-account $n}" "api-key"
      echo "Account $n configured with API key."
      ;;
    *)
      die "invalid choice"
      ;;
  esac
}

cmd_next() {
  local current max next
  current=$(get_current)
  max=$(get_max_account)

  [[ "$max" -eq 0 ]] && die "no Claude accounts configured. Run: ccc add 1"

  # Find next configured account (round-robin)
  next=$current
  for _ in 1 2 3 4 5 6 7; do
    next=$(( (next % 7) + 1 ))
    if [[ -f "$ACCOUNTS_DIR/${next}.json" ]] || [[ -d "$ACCOUNTS_DIR/${next}" ]]; then
      break
    fi
  done

  echo "$next" > "$CURRENT_FILE"

  local email
  email=$(get_profile_field "$next" "email")
  echo "Switched to account $next (${email:-unknown})"
  echo "Launching..."
  echo ""

  launch_account "$next" "$@"
}

cmd_current() {
  local current
  current=$(get_current)
  local email
  email=$(get_profile_field "$current" "email")
  echo "Current: account $current (${email:-unknown})"
}

# ─── Config Dir Helpers ───────────────────────────────────

_patch_onboarding_state() {
  # Copy essential onboarding/migration flags from ~/.claude.json into a config dir's .claude.json.
  # Without these, Claude Code shows the full first-run flow (mode select, login screen).
  local config_dir="$1"
  local config_json="$config_dir/.claude.json"
  local home_json="$HOME/.claude.json"
  [[ -f "$home_json" ]] || return 0
  [[ -f "$config_json" ]] || return 0
  python3 -c "
import json, sys
home = json.load(open('$home_json'))
conf = json.load(open('$config_json'))
KEYS = [
    'hasCompletedOnboarding', 'lastOnboardingVersion', 'numStartups',
    'migrationVersion', 'installMethod', 'hasAvailableSubscription',
    'hasAvailableMaxSubscription', 'opusProMigrationComplete',
    'sonnet1m45MigrationComplete', 'opus45MigrationComplete',
    'sonnet45MigrationComplete', 'thinkingMigrationComplete',
    'optionAsMetaKeyInstalled', 'shiftEnterKeyBindingInstalled',
    'officialMarketplaceAutoInstallAttempted', 'officialMarketplaceAutoInstalled',
]
changed = False
for k in KEYS:
    if k in home and k not in conf:
        conf[k] = home[k]
        changed = True
if changed:
    with open('$config_json', 'w') as f:
        json.dump(conf, f)
" 2>/dev/null
}

# ─── Profile Management ───────────────────────────────────

_update_profile() {
  local n="$1" email="$2" method="$3"
  python3 -c "
import json, os
f = '$PROFILES_FILE'
try:
    d = json.load(open(f))
except:
    d = {'accounts': {}}
d.setdefault('accounts', {})['$n'] = {'email': '$email', 'method': '$method'}
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" 2>/dev/null
}

# ─── Main ─────────────────────────────────────────────────

main() {
  local cmd="${1:-}"

  case "$cmd" in
    "")
      # Default: launch with current logged-in account
      exec claude
      ;;
    mm|minimax)
      shift
      local mm_settings="$ACCOUNTS_DIR/mm.json"
      [[ -f "$mm_settings" ]] || mm_settings="$HOME/.claude/settings-mm.json"
      [[ -f "$mm_settings" ]] || die "MiniMax not configured."
      launch_with_settings "$mm_settings" "$@"
      ;;
    [1-7])
      shift
      launch_account "$cmd" "$@"
      ;;
    next|rotate)
      shift
      cmd_next "$@"
      ;;
    status|ls)
      cmd_status
      ;;
    login)
      shift
      [[ $# -ge 1 ]] || die "usage: ccc login <1-7>"
      cmd_login "$1"
      ;;
    add)
      shift
      [[ $# -ge 1 ]] || die "usage: ccc add <1-7|mm> [email]"
      cmd_add "$@"
      ;;
    current)
      cmd_current
      ;;
    extract)
      shift
      [[ $# -ge 1 ]] || die "usage: ccc extract <1-7>"
      [[ "$1" =~ ^[1-7]$ ]] || die "account must be 1-7, got: $1"
      python3 "$HOME/.claude/accounts/rotation-engine.py" extract "$1"
      ;;
    setup-token)
      shift
      [[ $# -ge 1 ]] || die "usage: ccc setup-token <1-7> <token>"
      local n="$1"
      [[ "$n" =~ ^[1-7]$ ]] || die "account must be 1-7, got: $n"

      if [[ $# -ge 2 ]]; then
        local token="$2"
      else
        read -rsp "Paste the setup-token for account $n: " token
        echo ""
      fi

      [[ -n "$token" ]] || die "token cannot be empty"

      # Store the long-lived token
      mkdir -p "$HOME/.claude/accounts/tokens"
      echo "$token" > "$HOME/.claude/accounts/tokens/${n}.token"
      chmod 600 "$HOME/.claude/accounts/tokens/${n}.token"

      local email
      email=$(python3 -c "
import json
try:
    d = json.load(open('$HOME/.claude/accounts/profiles.json'))
    print(d.get('accounts',{}).get('$n',{}).get('email','account $n'))
except: print('account $n')
" 2>/dev/null)

      echo "Stored 1-year token for account $n ($email)"
      ;;
    resume)
      shift
      [[ $# -ge 1 ]] || die "usage: ccc resume <name|uuid>"
      local resume_target="$1"

      # If not a UUID, look up in session name registry
      if [[ ! "$resume_target" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
        local sid
        sid=$(python3 "$HOME/.claude/accounts/rotation-engine.py" find-name "$resume_target" 2>/dev/null)
        if [[ -n "$sid" ]]; then
          echo "Resolved '$resume_target' → $sid"
          resume_target="$sid"
        else
          die "no session named '$resume_target'. Use 'ccc names' to list."
        fi
      fi

      local current
      current=$(get_current)
      local rotation_config_dir="$ACCOUNTS_DIR/config-${current}"
      if [[ -d "$rotation_config_dir" ]]; then
        export CLAUDE_CONFIG_DIR="$rotation_config_dir"
        _patch_onboarding_state "$rotation_config_dir"
        exec claude --resume "$resume_target"
      else
        exec claude --resume "$resume_target"
      fi
      ;;
    name)
      shift
      [[ $# -ge 2 ]] || die "usage: ccc name <name> <session-uuid>"
      python3 "$HOME/.claude/accounts/rotation-engine.py" save-name "$1" "$2" "$(pwd)"
      ;;
    names)
      python3 "$HOME/.claude/accounts/rotation-engine.py" list-names "$(pwd)"
      ;;
    swap)
      shift
      [[ $# -ge 1 ]] || die "usage: ccc swap <1-7>"
      [[ "$1" =~ ^[1-7]$ ]] || die "account must be 1-7, got: $1"
      python3 "$HOME/.claude/accounts/rotation-engine.py" swap "$1"
      ;;
    verify)
      python3 "$HOME/.claude/accounts/rotation-engine.py" verify
      ;;
    setup)
      echo "Setting up per-account config dirs..."
      python3 "$HOME/.claude/accounts/rotation-engine.py" setup
      ;;
    quota)
      python3 "$HOME/.claude/accounts/rotation-engine.py" status
      ;;
    refresh)
      python3 "$HOME/.claude/accounts/rotation-engine.py" refresh
      ;;
    help|-h|--help)
      cat <<'HELP'
ccc — Claude Code multi-account launcher

PROVIDERS:
  ccc                  Launch with default account
  ccc mm               Launch with MiniMax
  ccc 1-7              Launch with specific Claude account
  ccc next             Rotate to next account (round-robin)

MANAGEMENT:
  ccc status           Show all configured accounts
  ccc quota            Show quota state + rotation priority
  ccc current          Show current rotation account
  ccc resume <name>    Resume a named session (from /rename or ccc name)
  ccc name <n> <uuid>  Save a session name for later resume
  ccc names            List saved session names for current dir
  ccc add <N> [email]  Add/configure account N (1-7 or mm)
  ccc login <N>        OAuth login for account N (1-7)
  ccc extract <N>      Save current keychain creds as account N
  ccc swap <N>         Swap keychain to account N (no browser)
  ccc verify           Check for credential cross-contamination
  ccc help             This message

SETUP (one-time per account):
  1. ccc login 1              OAuth login via browser
  2. ccc extract 1            Save credentials to rotation pool
  3. Repeat for accounts 2-7
  4. ccc swap 2               Test: switch to account 2 (no browser)

IN-SESSION (use /rotate command):
  /rotate                     Auto-pick best account and swap
HELP
      ;;
    *)
      # Pass through to claude (e.g., cc -p "hello", cc auth status)
      exec claude "$@"
      ;;
  esac
}

main "$@"
