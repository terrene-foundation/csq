.env
__pycache__/
*.pyc
/credentials/
.account.*
.DS_Store
**/.DS_Store

# Credential and session state files (security: never commit)
config-*/
.credentials.json
.csq-account
.current-account
.live-pid
.quota-cursor

# Gemini CLI-durable event log (spec 05 §5.8.1, security: never commit)
gemini-events-*.ndjson
gemini-events-*.corrupt.*

# Codex wham/usage raw + drift captures (PII-redacted on write but the
# diffs would still surface user_id / account_id / email shape drift
# across sessions; captures live only on the operator's machine).
accounts/codex-wham-raw.json
accounts/codex-wham-drift.json

# Rust build artifacts
target/

# csq-desktop frontend build artifacts
csq-desktop/node_modules/
csq-desktop/dist/

# Local-only research and notes folders
notes/
research/
internal/
upstream-internals/
*.research.md

# Phase test outputs and other ephemeral analysis data
journal/*-data/

# Runtime learning state — auto-appended on every session start.
# Tracking it produces churn on every commit and never carries useful diffs.
# Matches at any depth (csq-desktop/.claude/learning/ too) via the **/ prefix.
**/.claude/learning/

# Scheduled-task lock file — runtime state for the harness cron
# scheduler. Recreated on every session; has no diff value.
**/.claude/scheduled_tasks.lock

# IDE settings
.vscode/
**/.vscode/

# Session notes (ephemeral, per-machine)
workspaces/**/.session-notes

# COC eval environment — durable code (lib/, schemas/, tests/, fixtures/,
# suites/, conftest.py, run.py) is tracked. Only ephemeral run state is
# ignored. The legacy `coc-eval/coc-env/` workspace and per-run results
# are local-only.
coc-eval/__pycache__/
coc-eval/.pytest_cache/
coc-eval/.benchmarks/
coc-eval/coc-env/
coc-eval/results/
coc-eval/scaffolds/output/
coc-eval/run-environment-pin.json
coc-eval/**/__pycache__/
.playwright-mcp/
.claude/worktrees/
